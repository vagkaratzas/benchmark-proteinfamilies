/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // pre
    withName: 'REMOVE_DUPLICATE_BRANCHES' {
        publishDir = [
            path: { "${params.outdir}/pre/interpro" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'EXTRACT_VALID_INTERPRO_IDS' {
        publishDir = [
            path: { "${params.outdir}/pre/interpro" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'EXTRACT_CANDIDATE_INTERPRO_FAMILIES' {
        publishDir = [
            path: { "${params.outdir}/pre/interpro" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'EXTRACT_HAMAP_METADATA' {
        publishDir = [
            path: { "${params.outdir}/pre/families/num_proteins" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'EXTRACT_NCBIFAM_METADATA' {
        publishDir = [
            path: { "${params.outdir}/pre/families/num_proteins" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'EXTRACT_PANTHER_METADATA' {
        publishDir = [
            path: { "${params.outdir}/pre/families/num_proteins" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'EXTRACT_PFAM_METADATA' {
        publishDir = [
            path: { "${params.outdir}/pre/families/num_proteins" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'FILTER_VALID_CANDIDATE_FAMILIES' {
        publishDir = [
            path: { "${params.outdir}/pre/interpro" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'SAMPLE_INTERPRO' {
        publishDir = [
            path: { "${params.outdir}/pre/interpro" },
            mode: params.publish_dir_mode,
            enabled: false,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CONVERT_SAMPLED_TO_FASTA' {
        publishDir = [
            path: { "${params.outdir}/pre/families/sampled" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'COMBINE_DB_FASTA' {
        publishDir = [
            path: { "${params.outdir}/pre/families/sampled" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'DIAMOND_MAKEDB' {
        publishDir = [
            path: { "${params.outdir}/pre/diamond" },
            mode: params.publish_dir_mode,
            enabled: false,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'DIAMOND_BLASTP' {
        publishDir = [
            path: { "${params.outdir}/pre/diamond" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'IDENTIFY_UNIPROT_DECOYS' {
        publishDir = [
            path: { "${params.outdir}/pre/decoys" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'COMBINE_DECOY_FASTA' {
        publishDir = [
            path: { "${params.outdir}/pre" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // post
    withName: 'CALCULATE_SEQUENCE_STATS' {
        publishDir = [
            path: { "${params.outdir}/qc" },
            mode: params.publish_dir_mode,
            enabled: false,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CALCULATE_DB_SEQUENCE_COVERAGE' {
        publishDir = [
            path: { "${params.outdir}/qc" },
            mode: params.publish_dir_mode,
            enabled: false,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'ANALYZE_RECRUITED_DECOYS' {
        publishDir = [
            path: { "${params.outdir}/qc" },
